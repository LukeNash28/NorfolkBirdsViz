allStopovers <- c(allStopovers, list(data))
}
shapiroResults <- lapply(pseudoResiduals$residuals, function(residuals){
if(length(residuals) > 3 & length(residuals) < 5000){
shapiro.test(residuals)
} else {
NA
}
})
shapiroSigs <- sapply(shapiroResults, function(x) x$p.value)
pseudoResiduals$shapiro <- shapiroSigs
dwResults <- lapply(pseudoResiduals$residuals, function(residuals){
dwtest(residuals ~ 1)
})
dwStats <- sapply(dwResults, function(x) x$statistic)
pseudoResiduals$dw <- dwStats
fitInfo <- pseudoResiduals %>%
unnest(residuals)
probsInfo <- pseudoResiduals %>%
unnest(probs)
fitInfo <- fitInfo %>%
filter(!is.na(residuals) & !is.nan(residuals) & is.finite(residuals))
pseudoResiduals <- pseudoResiduals %>%
filter(!is.na(shapiro) & !is.nan(shapiro) & is.finite(shapiro)) %>%
filter(!is.na(dw) & !is.nan(dw) & is.finite(dw))
probsInfo <- probsInfo %>%
filter(!is.na(probs) & !is.nan(probs) & is.finite(probs))
residualsPlot <- ggplot(fitInfo, aes(x = residuals, fill = as.factor(series)))+
geom_density(color = "black")+
labs(x = "Pseudo-Residuals", y = "Frequency")+
theme_classic()+
theme(legend.position = "none")
shapiroPlot <- ggplot(pseudoResiduals, aes(x = "", y = shapiro))+
geom_violin(position = "dodge", fill = "red", color = "red", alpha = 0.2)+
geom_hline(yintercept = 0.05, linetype = "dashed")+
labs(main = "Distribution of Shapiro-Wilk test p-values", x = "", y = "p-value")+
theme_classic()+
scale_y_continuous(limits = c(0,1))
dwPlot <- ggplot(pseudoResiduals, aes(x = "", y = dw))+
geom_violin(position = "dodge", fill = "blue", color = "blue", alpha = 0.2)+
geom_hline(yintercept = 2, linewidth = 1)+
geom_hline(yintercept = 1.5, linetype = "dashed", linewidth = 0.5)+
geom_hline(yintercept = 2.5, linetype = "dashed", linewidth = 0.5)+
labs(main = "Distribution of Durbin-Watson test p-values", x = "", y = "DW score")+
theme_classic()+
scale_y_continuous(limits = c(0,4))
probPlot <- ggplot(probsInfo, aes(x = "", y = probs))+
geom_violin(position = "dodge", fill = "darkgreen", color = "darkgreen", alpha = 0.2)+
labs(main = "Distribution of state assignment probabilities", x = "", y = "Probability")+
theme_classic()+
scale_y_continuous(limits = c(0,1))
outputPlot <- ggarrange(residualsPlot,
ggarrange(shapiroPlot, dwPlot, probPlot,
labels = c("B", "C", "D"),
ncol = 1, nrow = 3),
labels = c("A", ""),
ncol = 2, nrow = 1,
heights = c(1,1))
plotList <- list(residualsPlot, shapiroPlot, dwPlot, probPlot)
output <- list(estimates = allStopovers, fits = pseudoResiduals, plots = plotList)
show(outputPlot)
print(paste0("Number of rejected models: ", rejectedModels))
return(output)
}
